}

.lh_home .section_navbar.is-scrolled .nav_menu-button .menu-icon_line-top, .lh_home .section_navbar.is-scrolled .nav_menu-button .menu-icon_line-middle, .lh_home .section_navbar.is-scrolled .nav_menu-button .menu-icon_line-bottom {
