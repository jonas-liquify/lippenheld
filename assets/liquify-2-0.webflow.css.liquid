  --lh_top_bot: 5rem;
  --lh_small: 1.5rem;
  --lh_xx_small: 0.75rem;
  --lh_large: 3.75rem;
  --lh_section_gap: 3.375rem;
  --lh_hero_stack: 1.5rem;
  --lh_font_outfit: "Outfit", sans-serif;
  --lh_font_cormorant: "Cormorant Infant", serif;
  --lh_font_playfair: "Playfair Display", serif;
}

.lh_home {
