/* =============================================================================
   Lippenheld – global (ehem. lippenheld-home.css)
   ============================================================================= */

/* Lippenheld: Nav-Drawer (Mini-Cart + Suche) — Layout gemäß Figma, nutzt bestehende .w--open / Alpine */

:root {
  --lh_drawer_w: 26.25rem;
  --lh_drawer_ink: #232e20;
  --lh_drawer_black: #26261f;
  --lh_drawer_olive: #afbaab;
  --lh_drawer_muted-row: #f7f7f7;
  --lh_drawer_upsell-bg: #efefef;
  --lh_drawer_shipping: #3fa842;
}

/* Overlay: Warenkorb = Drawer rechts; Suche = Top-Sheet (Figma) */
.nav_mini-cart-holder.w--open {
  flex-direction: row;
  justify-content: flex-end;
  align-items: stretch;
}

.nav_predictive-search-holder.w--open {
  flex-direction: column;
  justify-content: flex-start;
  align-items: stretch;
  -webkit-backdrop-filter: blur(2.55px);
  backdrop-filter: blur(2.55px);
}

.nav_mini-cart-close,
.nav_predictive-search-close {
  flex: 1 1 auto;
  min-width: 0;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}

.lh_nav_drawer_panel {
  box-sizing: border-box;
  width: var(--lh_drawer_w);
  max-width: 100vw;
  flex: 0 0 var(--lh_drawer_w);
  height: 100vh;
  max-height: 100dvh;
  padding: 1.25rem 0 0;
  background-color: #fff;
  flex-direction: column;
  display: flex;
  transform: translateX(100%);
  transition: transform 0.28s ease;
  box-shadow: -0.5rem 0 1.5rem rgba(38, 38, 31, 0.08);
}

.nav_mini-cart-holder.w--open .lh_nav_drawer_panel {
  transform: translateX(0);
}

.nav_predictive-search-holder.w--open .lh_search_sheet.lh_nav_drawer_panel {
  transform: none;
  transition: none;
}

.nav_predictive-search-holder.w--open .nav_predictive-search-close {
  position: absolute;
  inset: 0;
  z-index: 0;
  flex: 1 1 auto;
  min-height: 0;
}

.nav_predictive-search-holder.w--open .predictive-search_component.lh_search_sheet.lh_nav_drawer_panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 100%;
  flex: 0 0 auto;
  height: auto;
  max-height: none;
  min-height: 0;
  box-sizing: border-box;
  box-shadow: 0 -0.25rem 1.5rem rgba(0, 0, 0, 0.26);
  padding: 2.5rem clamp(1.25rem, 5vw, 5rem) 5rem;
  gap: 2.5rem;
}

.lh_search_sheet_toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  width: 100%;
  flex-shrink: 0;
}

.lh_search_sheet_query {
  flex: 1 1 auto;
  min-width: 0;
  max-width: 52rem;
}

.lh_search_sheet .predictive-search_input-holder {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 0.5rem 0.75rem 0.75rem;
  border: none;
  background-color: #f7f7f7;
  min-height: 3.25rem;
}

.lh_search_sheet_search_icon {
  flex-shrink: 0;
  width: 1.75rem;
  height: 1.75rem;
  color: var(--lh_drawer_black, #26261f);
}

.lh_search_sheet .predictive-search_input {
  flex: 1 1 auto;
  min-width: 0;
  padding: 0 0.5rem 0 0;
  font-family: var(--lh_font_playfair, "Playfair Display", serif);
  font-size: 1rem;
  line-height: 1.47;
  letter-spacing: 0.03em;
  color: var(--lh_drawer_black, #26261f);
}

.lh_search_sheet .predictive-search_input::placeholder {
  opacity: 0.6;
}

.lh_search_sheet_close {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 0.75rem;
  padding: 0.125rem 0 0;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--lh_drawer_black, #26261f);
  flex-shrink: 0;
}

.lh_search_sheet_close_icon {
  display: flex;
  width: 1.1rem;
