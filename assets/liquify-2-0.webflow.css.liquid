}

.lh_home .section_navbar.is-scrolled .nav_menu .nav_dropdown-toggle a div, .lh_home .section_navbar.is-scrolled .nav_menu .nav_dropdown-toggle {
  color: var(--lh_black);
}

.lh_home .section_navbar.is-scrolled .nav_menu .dropdown-icon {
  color: var(--lh_black);
}

.lh_home .section_navbar.is-scrolled .nav_shop-icon {
  color: var(--lh_black);
}

.lh_home .section_navbar.is-scrolled .nav_menu-button {
