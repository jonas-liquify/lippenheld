  background: rgba(255,255,255,0.92);
  border: 1px solid rgba(38,38,31,0.08);
  padding: 1.5rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.lh_pdp_quote_title {
  font-family: Outfit,sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #232e20;
  margin: 0;
}

.lh_pdp_quote_text {
  font-size: 0.875rem;
  line-height: 1.55;
  color: #26261f;
  margin: 0;
}

.lh_pdp_why_cta {
  margin-top: 2.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}

.lh_pdp_why_points {
  font-family: Outfit,sans-serif;
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(35,46,32,0.55);
  margin: 0;
}

.lh_pdp_trustpilot {
  background: #fff;
}

.lh_pdp_faq {
  background: #fafafa;
}

.lh_pdp_faq_layout {
  display: grid;
  grid-template-columns: minmax(0,280px) minmax(0,1fr);
  gap: 3rem;
  align-items: start;
}

@media screen and (max-width: 767px) {
  .lh_pdp_faq_layout {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
}

.lh_pdp_faq_heading {
  font-family: "Cormorant Infant",Georgia,serif;
  font-size: 1.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #26261f;
  margin: 0 0 0.75rem;
}

.lh_pdp_faq_lead {
  font-size: 0.9375rem;
  line-height: 1.5;
  color: rgba(38,38,31,0.75);
  margin: 0;
}

.lh_pdp_faq_list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.lh_pdp_faq_item {
  border-bottom: 1px solid rgba(38,38,31,0.12);
  padding: 0.75rem 0;
}

.lh_pdp_faq_item .lh_accordion_head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  cursor: pointer;
  list-style: none;
}

.lh_pdp_faq_item .lh_accordion_head::-webkit-details-marker {
  display: none;
}

.lh_pdp_social {
  background: #fff;
}

.lh_pdp_social_inner {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.lh_pdp_social_kicker {
  font-family: Outfit,sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(38,38,31,0.5);
  margin: 0;
}

.lh_pdp_social_links {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 1rem 1.75rem;
}

.lh_pdp_social_link {
  font-family: Outfit,sans-serif;
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: underline;
  text-underline-offset: 0.2em;
  color: #26261f;
}