<div class="lh_review_tile" tabindex="0" li-block="_Review Kachel" {{ block.shopify_attributes }}>
                    {% if block.settings.image_bild %}
{{ block.settings.image_bild | image_url: width: 1000 | image_tag: loading: 'lazy' }}
{% else %}
<img src="{{ 'platzhalter.svg' | asset_url }}" alt="" loading="lazy">
{% endif %}
                    <div class="lh_review_caption"><div> {{ block.settings.richtext_zitat }} </div><p>
{{ block.settings.text_name }}
</p></div>
                </div> {% schema %} {
    "name": "Review Kachel",
    "settings": [
        {
            "id": "image_bild",
            "type": "image_picker",
            "label": "Bild"
        },
        {
            "id": "richtext_zitat",
            "type": "richtext",
            "label": "Zitat",
            "default": "<p>Alles andere hat meine Lippen nur ausgetrocknet.<\/p>"
        },
        {
            "id": "text_name",
            "type": "text",
            "label": "Name",
            "default": "Grace"
        }
    ],
    "presets": [
        {
            "name": "Review Kachel",
            "blocks": []
        }
    ],
    "tag": null
} {% endschema %}