<div class="lh_pdp_ugc" id="reviews" li-block="UGC Galerie" li-block:category="Medien" {{ block.shopify_attributes }}>
                    <p class="lh_pdp_ugc_kicker">
{{ block.settings.text_ugc_uberschrift }}
</p>
                    <div class="lh_pdp_ugc_grid"><div class="lh_pdp_ugc_cell">{% if block.settings.image_ugc_1 %}
{{ block.settings.image_ugc_1 | image_url: width: 1000 | image_tag: loading: 'lazy' }}
{% else %}
<img src="{{ 'platzhalter.svg' | asset_url }}" alt="" loading="lazy">
{% endif %}</div><div class="lh_pdp_ugc_cell">{% if block.settings.image_ugc_2 %}
{{ block.settings.image_ugc_2 | image_url: width: 1000 | image_tag: loading: 'lazy' }}
{% else %}
<img src="{{ 'platzhalter.svg' | asset_url }}" alt="" loading="lazy">
{% endif %}</div><div class="lh_pdp_ugc_cell">{% if block.settings.image_ugc_3 %}
{{ block.settings.image_ugc_3 | image_url: width: 1000 | image_tag: loading: 'lazy' }}
{% else %}
<img src="{{ 'platzhalter.svg' | asset_url }}" alt="" loading="lazy">
{% endif %}</div><div class="lh_pdp_ugc_cell lh_pdp_ugc_more">
{{ block.settings.text_ugc_mehr_anzahl }}
</div></div>
                </div> {% schema %} {
    "name": "UGC Galerie",
    "settings": [
        {
            "id": "text_ugc_uberschrift",
            "type": "text",
            "label": "UGC \u00dcberschrift",
            "default": "Your journeys, your results"
        },
        {
            "id": "image_ugc_1",
            "type": "image_picker",
            "label": "UGC 1"
        },
        {
            "id": "image_ugc_2",
            "type": "image_picker",
            "label": "UGC 2"
        },
        {
            "id": "image_ugc_3",
            "type": "image_picker",
            "label": "UGC 3"
        },
        {
            "id": "text_ugc_mehr_anzahl",
            "type": "text",
            "label": "UGC Mehr Anzahl",
            "default": "12+"
        }
    ],
    "presets": [
        {
            "name": "UGC Galerie",
            "category": "Medien",
            "blocks": []
        }
    ],
    "tag": null
} {% endschema %}