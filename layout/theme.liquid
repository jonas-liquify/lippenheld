(function () {
        function initLhWhyAccordion() {
          var panel = document.querySelector('.lh_why_panel');
          if (!panel) return;
          var items = panel.querySelectorAll('details.lh_accordion_item');
          items.forEach(function (detail) {
            detail.addEventListener('toggle', function () {
              if (!detail.open) return;
              items.forEach(function (other) {
                if (other !== detail) other.open = false;
              });
            });
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initLhWhyAccordion);
        } else {
          initLhWhyAccordion();
        }
      })();

      (function () {
        function initLhNavScroll() {
          var bar = document.querySelector('.lh_home .section_navbar');
          if (!bar) return;
          var html = document.documentElement;
          var forceScrolled =
            html.classList.contains('lh_product') ||
            html.classList.contains('lh_nav_solid');
          var threshold = 48;
          function update() {
            if (forceScrolled) {
              bar.classList.add('is-scrolled');
              return;
            }
            bar.classList.toggle('is-scrolled', window.scrollY > threshold);
          }
          update();
          if (!forceScrolled) {
            window.addEventListener('scroll', update, { passive: true });
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initLhNavScroll);
        } else {
          initLhNavScroll();
        }
      })();

      (function () {
        function initLhHomeSwipers() {
          if (typeof Swiper === 'undefined') return;
          var root = document.querySelector('.lh_home');
          if (!root) return;

          root.querySelectorAll('.lh_swiper_reviews').forEach(function (el) {
            if (el.dataset.lhSwiperInit) return;
            el.dataset.lhSwiperInit = '1';
            new Swiper(el, {
              slidesPerView: 'auto',
              spaceBetween: 4,
              speed: 450,
              grabCursor: true,
              watchOverflow: true,
              keyboard: { enabled: true, onlyInViewport: true },
              breakpoints: {
                768: { spaceBetween: 8 },
              },
            });
          });

          root.querySelectorAll('.lh_swiper_lip').forEach(function (el) {
            if (el.dataset.lhSwiperInit) return;
            el.dataset.lhSwiperInit = '1';
            var bar = el.querySelector('.lh_lip_scrollbar');
            new Swiper(el, {
              slidesPerView: 'auto',
              spaceBetween: 4,
              speed: 400,
              grabCursor: true,
              watchOverflow: true,
              keyboard: { enabled: true, onlyInViewport: true },
              breakpoints: {
                768: { slidesPerView: 2, spaceBetween: 4 },
                992: { slidesPerView: 4, spaceBetween: 4 },
              },
              scrollbar: bar
                ? { el: bar, draggable: true, hide: false }
                : undefined,
            });
          });

          root.querySelectorAll('.lh_swiper_trusted').forEach(function (el) {
            if (el.dataset.lhSwiperInit) return;
            el.dataset.lhSwiperInit = '1';
            new Swiper(el, {
              slidesPerView: 'auto',
              spaceBetween: 4,
              speed: 450,
              grabCursor: true,
              watchOverflow: true,
              keyboard: { enabled: true, onlyInViewport: true },
              breakpoints: {
                768: { spaceBetween: 8 },
              },
            });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initLhHomeSwipers);
        } else {
          initLhHomeSwipers();
        }
      })();











































































































































































</script>{% render 'search_javascript' %}</body></html>
