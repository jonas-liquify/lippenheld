        </div> {% schema %} {
    "tag": "section",
    "name": "Search",
    "class": "section_filter",
    "settings": [
        {
            "id": "text_filter",
            "type": "text",
            "label": "Filter",
            "default": "Filters"
        },
        {
            "id": "text_clear_all",
            "type": "text",
            "label": "Clear all",
            "default": "Clear all"
