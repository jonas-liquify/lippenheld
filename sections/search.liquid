<div class="padding-global padding-section-medium">
          <div class="container-large">
            <div class="filters_top">
              <div class="filter_headline">
                <h1 class="heading-style-h2" li-object="search.terms | escape ">{{ search.terms | escape  }}</h1>
              </div>
              <div class="spacer-large"></div>
            </div>
            {% paginate search.results by 50 %}
    <div class="filter_layout" li-paginate:by="50" li-paginate="search.results" by="50">
              <div class="filter_filters-wrapper" id="w-node-_678e0483-bbe4-e79a-1722-b169c587feae-c587feae">
                <form class="filter_form_component" action="{{ routes.search_url }}" method="get" role="search">
                  <div class="filter_form" id="w-node-_265c4342-3d21-e8bf-dfee-efec035c3507-c587feae">
                    <div class="filter_form-header">
                      <div class="filter_heading">
{{ section.settings.text_filter }}
</div>
                      <a class="button is-link hide-tablet w-inline-block" li-object:href="routes.search_url" href="{{ routes.search_url }}">
                        <div>
{{ section.settings.text_clear_all }}
</div>
                      </a>
                    </div>
                    <div class="filter_results-wrapper">
                      <div class="filter_results-text">
                        <span li-object="search.results_count | append: ' '">{{ search.results_count | append: ' ' }}</span>
                         
                        <span>
{{ section.settings.text_products_shown }}
</span>
                      </div>
                    </div>
                    <div class="filter_form-field-wrapper">
                      <input class="form_input" name="type" type="hidden" value="product">
                      <label class="form_hidden-label" for="filter-search">Search for Products</label>
                      <input class="form_input" name="q" type="search" id="filter-search" value="{{ search.terms | escape }}" placeholder="Search">
                    </div>
                    <div class="filter_scroll-wrapper">
                      <div class="filter_filter-group-list">
                        {% for filter in search.filters %}    <div class="filter_filter-group" li-for="filter in search.filters">
                                    
                          
                            {% if filter.values.size > 1 %}    <div li-if="filter.values.size > 1">
    
                            <div class="filter_filter-group-heading">
                              <div class="text-size-medium text-weight-semibold" li-object="filter.label">{{ filter.label }}</div>
                            </div>
                            <div class="filter_list">
                              {% for filter_value in filter.values %}    <div class="filter_item" li-for="filter_value in filter.values">
                                    
                                
                            <a class="{% if filter_value.count == 0 and filter_value.active == false %}filter_form_checkbox is-disabled{% else %}filter_form_checkbox{% endif %}" href="{% if filter_value.active %}{{ filter_value.url_to_remove }}{% else %}{{ filter_value.url_to_add }}{% endif %}">
                                  <div class="{% if filter_value.active %}filter_form_checkbox-icon is-checked{% else %}filter_form_checkbox-icon{% endif %}"></div>
                                  <div class="filter_form_checkbox-label">
                                    <span li-object="filter_value.label | append: ' '">{{ filter_value.label | append: ' ' }}</span>
                                     ( 
                                    <span li-object="filter_value.count">{{ filter_value.count }}</span>
                                     )
                                  </div>
                                </a>
                            
                              
                        </div>
{% endfor %}
                            </div>
                              </div>
{% endif %}
                            
                        
                        </div>
{% endfor %}
                      </div>
                    </div>
                  </div>
                </form>
                <a class="filter_tablet-modal-close-button w-inline-block" data-w-id="678e0483-bbe4-e79a-1722-b169c587fede" href="#">
                  <img class="icon-1x1-small" src="https://uploads-ssl.webflow.com/624380709031623bfe4aee60/624380709031623afe4aee7e_icon_close-modal.svg" alt="">
                </a>
              </div>
              <a class="filter_tablet-filters-button w-inline-block" data-w-id="63614b06-d13c-4caa-b5ce-a7c7ab356686" href="#">
                <img class="button-icon-left" alt="" loading="lazy" src="https://uploads-ssl.webflow.com/624380709031623bfe4aee60/62942b9f00484cf074e6f851_icon-filters.svg">
                <div>Filters</div>
              </a>
              <div class="filter_feed" id="w-node-_63614b06-d13c-4caa-b5ce-a7c7ab35668a-ab35667c">
                <div class="filter_feed-header">
                  <div class="filter_tags-wrapper">
                    {% for filters in search.filters %}    <div class="filter_tags-inner-wrapper" li-for="filters in search.filters">
                                    
                      
                            {% for filter_value in filters.active_values %}    <div class="filter_tag" li-for="filter_value in filters.active_values">
                                    
                        
                            <div li-object="filter_value.label">{{ filter_value.label }}</div>
                            
                        
                            <a class="filter_close w-inline-block" aria-label="Remove Filter" li-object:href="filter_value.url_to_remove" href="{{ filter_value.url_to_remove }}">
                          <div class="filter_close-icon w-embed">
                            <svg width="100%" height="100%" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M17.1266 16.773L16.7729 17.1266C16.5777 17.3218 16.2611 17.3218 16.0658 17.1266L12 13.0607L7.9341 17.1265C7.73888 17.3218 7.42229 17.3218 7.22702 17.1265L6.87347 16.773C6.6782 16.5777 6.6782 16.2612 6.87347 16.0659L10.9394 12L6.87347 7.93413C6.6782 7.73891 6.6782 7.42232 6.87347 7.22705L7.22702 6.8735C7.42228 6.67824 7.73888 6.67824 7.9341 6.8735L12 10.9394L16.0658 6.8735C16.2611 6.67824 16.5777 6.67824 16.7729 6.8735L17.1266 7.22705C17.3218 7.42231 17.3218 7.73891 17.1266 7.93413L13.0607 12L17.1266 16.0659C17.3218 16.2612 17.3218 16.5777 17.1266 16.773Z" fill="currentColor"></path>
                            </svg>
                          </div>
                        </a>
                            
                      
                        </div>
{% endfor %}
                            
                    
                        </div>
{% endfor %}
                  </div>
                  <select class="sort_select filter_checkbox" id="sort-by" li-for:inside="option in search.sort_options">
        {% for option in search.sort_options %}                            
                    
                            <option value="{{ option.value }}" {% if option.value == search.sort_by %}selected{% elsif option.value == search.default_sort_by %}selected{% endif %}>{{ option.name }}</option>
                            
                  
                    {% endfor %}    </select>
                </div>
                <div class="filter_product-list-wrapper w-dyn-list">
                  <div class="filter_product-list w-dyn-items" role="list">
                    {% for product in search.results %}    <div class="filter_product-list-item w-dyn-item" li-for="product in search.results" role="listitem">
                                    
                      
                            {% render 'product_item', product: product %}
                            
                    
                        </div>
{% endfor %}
                  </div>
                  {% if search.results == blank %}    <div class="filter_empty w-dyn-empty" li-if="search.results == blank">
    
                    <div class="heading-style-h6">No results found.</div>
                    <div class="spacer-xxsmall"></div>
                    <div>There are no results with this criteria. Try changing your search.</div>
                      </div>
{% endif %}
                </div>
                {% if paginate.pages > 1 %}    <nav class="pagination_component" li-if="paginate.pages > 1">
    
                  <ul class="pagination_list w-list-unstyled" role="list">
                    {% if paginate.previous %}    <li class="pagination_item" li-if="paginate.previous">
    
                      <a class="button is-secondary is-icon w-inline-block" li-object:href="paginate.previous.url" href="{{ paginate.previous.url }}">
                        <div class="pagination_arrow w-embed">
                          <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 8" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                            <path d="M1.67318 0.589844L6.26318 5.16984L10.8532 0.589844L12.2632 1.99984L6.26318 7.99984L0.263184 1.99984L1.67318 0.589844Z" fill="currentColor"></path>
                          </svg>
                        </div>
                        <div>Back</div>
                      </a>
                        </li>
{% endif %}
                    {% if paginate.previous == false %}    <li class="pagination_item" li-if="paginate.previous == false">
    
                      <a class="button is-secondary is-icon text-style-muted pointer-events-off w-inline-block" li-object:href="paginate.previous.url" href="{{ paginate.previous.url }}">
                        <div class="pagination_arrow w-embed">
                          <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 8" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                            <path d="M1.67318 0.589844L6.26318 5.16984L10.8532 0.589844L12.2632 1.99984L6.26318 7.99984L0.263184 1.99984L1.67318 0.589844Z" fill="currentColor"></path>
                          </svg>
                        </div>
                        <div>Back</div>
                      </a>
                        </li>
{% endif %}
                    {% for part in paginate.parts %}    <li class="pagination_item" li-for="part in paginate.parts">
                                    
                      
                            {% if part.is_link %}    <div li-if="part.is_link">
    
                        <a class="pagination_count w-inline-block" li-object:href="part.url" href="{{ part.url }}">
                          <div class="text-style-link" li-object="part.title">{{ part.title }}</div>
                        </a>
                          </div>
{% endif %}
                            
                      
                            {% if part.is_link == false %}    <div li-if="part.is_link == false">
    
                        {% if part.is_link != true %}    <div li-if="part.is_link != true">
    
                          <div>
                            <div li-object="part.title" class="{% if part.title == paginate.current_page %}text-weight-semibold{% endif %}">{{ part.title }}</div>
                          </div>
                            </div>
{% endif %}
                          </div>
{% endif %}
                            
                    
                        </li>
{% endfor %}
                    {% if paginate.next == false %}    <li class="pagination_item" li-if="paginate.next == false">
    
                      <a class="button is-secondary is-icon text-style-muted pointer-events-off w-inline-block" li-object:href="paginate.next.url" href="{{ paginate.next.url }}">
                        <div>Next</div>
                        <div class="pagination_arrow is-right w-embed">
                          <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 8" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                            <path d="M1.67318 0.589844L6.26318 5.16984L10.8532 0.589844L12.2632 1.99984L6.26318 7.99984L0.263184 1.99984L1.67318 0.589844Z" fill="currentColor"></path>
                          </svg>
                        </div>
                      </a>
                        </li>
{% endif %}
                    {% if paginate.next %}    <li class="pagination_item" li-if="paginate.next">
    
                      <a class="button is-secondary is-icon w-inline-block" li-object:href="paginate.next.url" href="{{ paginate.next.url }}">
                        <div>Next</div>
                        <div class="pagination_arrow is-right w-embed">
                          <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 8" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                            <path d="M1.67318 0.589844L6.26318 5.16984L10.8532 0.589844L12.2632 1.99984L6.26318 7.99984L0.263184 1.99984L1.67318 0.589844Z" fill="currentColor"></path>
                          </svg>
                        </div>
                      </a>
                        </li>
{% endif %}
                  </ul>
                    </nav>
{% endif %}
              </div>
            </div>{% endpaginate %}
          </div>
        </div>
        <div class="hide w-embed w-script">
          <script>



























































































































































































































































































































































































              //sortierung
              Shopify.queryParams = {};
              // Preserve existing query parameters
              if (location.search.length) {
                var params = location.search.substr(1).split('&');
                for (var i = 0; i < params.length; i++) {
                  var keyValue = params[i].split('=');
                  if (keyValue.length) {
                    Shopify.queryParams[decodeURIComponent(keyValue[0])] = decodeURIComponent(keyValue[1]);
                  }
                }
              }
              // Update sort_by query parameter on select change
              document.querySelector('#sort-by').addEventListener('change', function(e) {
                var value = e.target.value;
                Shopify.queryParams.sort_by = value;
                location.search = new URLSearchParams(Shopify.queryParams).toString();
              });
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
          
