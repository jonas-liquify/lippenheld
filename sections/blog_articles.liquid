{% paginate blog.articles by 50 %}
    <div class="padding-global padding-section-small" li-paginate:by="50" li-paginate="blog.articles" by="50">
          <div class="container-large">
            <div class="blog_cms-wrapper w-dyn-list">
              {% if blog.articles != blank %}    <div class="blog_list w-dyn-items" li-if="blog.articles != blank" role="list">
    
                {% for article in blog.articles %}    <div class="blog_cms-item w-dyn-item" li-for="article in blog.articles" role="listitem">
                                    
                  
                            <a class="blog_item-grid w-inline-block" li-object:href="article.url" href="{{ article.url }}">
                    <div class="blog_tags-wrapper" id="w-node-c45bff24-6242-fee4-5061-f2f14b06a7be-4b06a7bd">
                      <img class="blog_img" src="{{ article.image | image_url: width: 450 }}" loading="lazy" id="w-node-c45bff24-6242-fee4-5061-f2f14b06a7bf-4b06a7bd" li-object:src="article.image | image_url: width: 450" alt="{{ article.image.alt }}" li-object:alt="article.image.alt">
                      <div class="blog_tag-row">
                        {% for tag in article.tags %}    <div class="blog_tag" li-for="tag in article.tags">
                                    
                          
                            <div li-object="tag">{{ tag }}</div>
                            
                        
                        </div>
{% endfor %}
                      </div>
                    </div>
                    <div class="spacer-small" id="w-node-_6b97875b-5fce-9f5a-43fd-5792b69faf23-4b06a7bd"></div>
                    <div class="blog_info-wrapper">
                      <h3 class="heading-style-h3" li-object="article.title">{{ article.title }}</h3>
                    </div>
                  </a>
                            
                
                        </div>
{% endfor %}
                  </div>
{% endif %}
              {% if blog.articles == blank %}    <div class="blog_cms-empty w-dyn-empty" li-if="blog.articles == blank">
    
                <div>No blog items found.</div>
                  </div>
{% endif %}
            </div>
            {% if paginate.pages > 1 %}    <nav class="pagination_component" li-if="paginate.pages > 1">
    
              <ul class="pagination_list w-list-unstyled" role="list">
                {% if paginate.previous %}    <li class="pagination_item" li-if="paginate.previous">
    
                  <a class="button is-secondary is-icon w-inline-block" li-object:href="paginate.previous.url" href="{{ paginate.previous.url }}">
                    <div class="pagination_arrow w-embed">
                      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 8" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                        <path d="M1.67318 0.589844L6.26318 5.16984L10.8532 0.589844L12.2632 1.99984L6.26318 7.99984L0.263184 1.99984L1.67318 0.589844Z" fill="currentColor"></path>
                      </svg>
                    </div>
                    <div>Back</div>
                  </a>
                    </li>
{% endif %}
                {% if paginate.previous == false %}    <li class="pagination_item" li-if="paginate.previous == false">
    
                  <a class="button is-secondary is-icon text-style-muted pointer-events-off w-inline-block" li-object:href="paginate.previous.url" href="{{ paginate.previous.url }}">
                    <div class="pagination_arrow w-embed">
                      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 8" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                        <path d="M1.67318 0.589844L6.26318 5.16984L10.8532 0.589844L12.2632 1.99984L6.26318 7.99984L0.263184 1.99984L1.67318 0.589844Z" fill="currentColor"></path>
                      </svg>
                    </div>
                    <div>Back</div>
                  </a>
                    </li>
{% endif %}
                {% for part in paginate.parts %}    <li class="pagination_item" li-for="part in paginate.parts">
                                    
                  
                            {% if part.is_link %}    <div li-if="part.is_link">
    
                    <a class="pagination_count w-inline-block" li-object:href="part.url" href="{{ part.url }}">
                      <div class="text-style-link" li-object="part.title">{{ part.title }}</div>
                    </a>
                      </div>
{% endif %}
                            
                  
                            {% if part.is_link == false %}    <div li-if="part.is_link == false">
    
                    <div li-object="part.title" class="{% if part.title == paginate.current_page %}text-weight-semibold{% endif %}">{{ part.title }}</div>
                      </div>
{% endif %}
                            
                
                        </li>
{% endfor %}
                {% if paginate.next == false %}    <li class="pagination_item" li-if="paginate.next == false">
    
                  <a class="button is-secondary is-icon text-style-muted pointer-events-off w-inline-block" li-object:href="paginate.next.url" href="{{ paginate.next.url }}">
                    <div>Next</div>
                    <div class="pagination_arrow is-right w-embed">
                      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 8" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                        <path d="M1.67318 0.589844L6.26318 5.16984L10.8532 0.589844L12.2632 1.99984L6.26318 7.99984L0.263184 1.99984L1.67318 0.589844Z" fill="currentColor"></path>
                      </svg>
                    </div>
                  </a>
                    </li>
{% endif %}
                {% if paginate.next %}    <li class="pagination_item" li-if="paginate.next">
    
                  <a class="button is-secondary is-icon w-inline-block" li-object:href="paginate.next.url" href="{{ paginate.next.url }}">
                    <div>Next</div>
                    <div class="pagination_arrow is-right w-embed">
                      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewbox="0 0 13 8" fill="none" preserveaspectratio="xMidYMid meet" aria-hidden="true" role="img">
                        <path d="M1.67318 0.589844L6.26318 5.16984L10.8532 0.589844L12.2632 1.99984L6.26318 7.99984L0.263184 1.99984L1.67318 0.589844Z" fill="currentColor"></path>
                      </svg>
                    </div>
                  </a>
                    </li>
{% endif %}
              </ul>
                </nav>
{% endif %}
          </div>
        </div>{% endpaginate %} {% schema %} {
    "tag": "section",
    "name": "Blog-Articles",
    "class": "section_blog-list",
    "presets": [
        {
            "name": "Blog-Articles",
            "category": "Liquify",
            "blocks": []
        }
    ],
    "enabled_on": {
        "templates": [
            "blog"
        ]
    }
} {% endschema %}