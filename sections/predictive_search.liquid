{% if predictive_search.performed %}    <div class="predictive-search_conditional" li-if="predictive_search.performed">
    
                                              {% assign first_column_results_size = predictive_search.resources.queries.size | plus: predictive_search.resources.collections.size | plus: predictive_search.resources.pages.size | plus: predictive_search.resources.articles.size | plus: predictive_search.resources.products.size %}
                                              {% if first_column_results_size > 0 %}    <div class="predictive-search_conditional" li-if="first_column_results_size > 0">
    
                                                {% if predictive_search.resources.queries.size > 0 or predictive_search.resources.collections.size > 0 %}    <div class="predictive-search_topic" li-if="predictive_search.resources.queries.size > 0 or predictive_search.resources.collections.size > 0">
    
                                                  <div class="predictive-search_headline">
                                                    <div class="lh_search_sheet_heading">
{{ section.settings.text_suche_treffer_vorschlage }}
</div>
                                                  </div>
                                                  <ul class="predictive-search_list w-list-unstyled lh_search_sheet_pill_list" role="list">
                                                    {% for query in predictive_search.resources.queries %}    <li class="predictive-search_item" li-for="query in predictive_search.resources.queries">
                                    
                                                      
                            <a class="predictive-search_link lh_search_sheet_pill w-inline-block" li-object:href="query.url" href="{{ query.url }}">
                                                        <div li-object="query.styled_text">{{ query.styled_text }}</div>
                                                      </a>
                            
                                                    
                        </li>
{% endfor %}
                                                    {% for collection in predictive_search.resources.collections %}    <li class="predictive-search_item" li-for="collection in predictive_search.resources.collections">
                                    
                                                      
                            <a class="predictive-search_link lh_search_sheet_pill w-inline-block" li-object:href="collection.url" href="{{ collection.url }}">
                                                        <div li-object="collection.title">{{ collection.title }}</div>
                                                      </a>
                            
                                                    
                        </li>
{% endfor %}
                                                  </ul>
                                                    </div>
{% endif %}
                                                {% if predictive_search.resources.products.size > 0 or predictive_search.resources.articles.size > 0 or predictive_search.resources.pages.size > 0 %}    <div class="predictive-search_topic" li-if="predictive_search.resources.products.size > 0 or predictive_search.resources.articles.size > 0 or predictive_search.resources.pages.size > 0">
    
                                                  <div class="predictive-search_headline">
                                                    <div class="lh_search_sheet_heading">
{{ section.settings.text_suche_treffer_produkte }}
</div>
                                                  </div>
                                                  <ul class="predictive-search_product-list w-list-unstyled lh_search_sheet_product_grid" role="list">
                                                    {% for product in predictive_search.resources.products %}    <li class="predictive-search_produt-item" li-for="product in predictive_search.resources.products">
                                    
                                                      
                            <a class="predictive-search_line-item lh_search_sheet_product_card w-inline-block" li-object:href="product.url" href="{{ product.url }}">
                                                        <div class="predictive-search_image-wrapper lh_search_sheet_product_visual">
                                                          <img class="predictive-search_image" li-object:src="product.featured_media | image_url: width: 150" li-object:alt="product.featured_image.alt" alt="{{ product.featured_image.alt }}" src="{{ product.featured_media | image_url: width: 150 }}" loading="lazy">
                                                        </div>
                                                        <div class="lh_search_sheet_rating" aria-hidden="true">
                                                          <span class="lh_search_sheet_rating_stars">★★★★★</span>
                                                           
                                                          <span class="lh_search_sheet_rating_val">4.9</span>
                                                        </div>
                                                        <div class="predictive-search_product-info lh_search_sheet_product_copy">
                                                          <div class="lh_search_sheet_product_titles">
                                                            <div class="text-size-regular text-weight-bold lh_search_sheet_product_title">
                                                              <span li-object="product.title">{{ product.title }}</span>
                                                            </div>
                                                            {% if product.type %}    <div class="lh_search_sheet_product_sub" li-if="product.type != blank" li-object="product.type">
    Typ    </div>
{% endif %}
                                                          </div>
                                                          <div class="text-size-small lh_search_sheet_product_price">
                                                            <span li-object="product.price | money">{{ product.price | money }}</span>
                                                          </div>
                                                        </div>
                                                      </a>
                            
                                                    
                        </li>
{% endfor %}
                                                  </ul>
                                                    </div>
{% endif %}
                                                {% if predictive_search.resources.articles.size > 0 or predictive_search.resources.pages.size > 0 %}    <div class="predictive-search_topic" li-if="predictive_search.resources.articles.size > 0 or predictive_search.resources.pages.size > 0">
    
                                                  <div class="predictive-search_headline">
                                                    <div class="lh_search_sheet_heading">
{{ section.settings.text_suche_treffer_seiten }}
</div>
                                                  </div>
                                                  <ul class="predictive-search_list w-list-unstyled lh_search_sheet_pill_list" role="list">
                                                    {% for page in predictive_search.resources.pages %}    <li class="predictive-search_item" li-for="page in predictive_search.resources.pages">
                                    
                                                      
                            <a class="predictive-search_link lh_search_sheet_pill w-inline-block" li-object:href="page.url" href="{{ page.url }}">
                                                        <div li-object="page.title">{{ page.title }}</div>
                                                      </a>
                            
                                                    
                        </li>
{% endfor %}
                                                  </ul>
                                                    </div>
{% endif %}
                                                  </div>
{% endif %}
                                              {% if first_column_results_size == 0 %}    <div class="predictive-search_conditional" li-if="first_column_results_size == 0">
    
                                                <div class="predictive-search_topic">
                                                  <div class="text-style-muted lh_search_sheet_empty">
                                                    Nichts gefunden unter " 
                                                    <span li-object="predictive_search.terms">{{ predictive_search.terms }}</span>
                                                     "
                                                  </div>
                                                </div>
                                                  </div>
{% endif %}
                                                </div>
{% endif %}
                                            {% unless predictive_search.performed %}    <div class="predictive-search_conditional" li-unless="predictive_search.performed">
    
                                              <div class="predictive-search_overflow lh_search_sheet_idle">
                                                <div class="predictive-search_topic">
                                                  <div class="predictive-search_headline">
                                                    <div class="lh_search_sheet_heading">
{{ section.settings.text_suche_bereich_vorschlage }}
</div>
                                                  </div>
                                                  <ul class="predictive-search_list w-list-unstyled lh_search_sheet_pill_list" role="list">
                                                    {% for block in section.blocks %}
    {% if block.type == "search-suggestion" %}
                    <li class="predictive-search_item" li-block="Search - Suggestion">
                                    
                                                      
                                    <a class="predictive-search_link lh_search_sheet_pill w-inline-block" href="{{ block.settings.url_link }}"> <div>{{ block.settings.text_text }}</div> </a>
                                    
                                                    
                            </li>
            {% endif %}
{% endfor %}
                                                  </ul>
                                                </div>
                                                <div class="predictive-search_topic">
                                                  <div class="predictive-search_headline">
                                                    <div class="lh_search_sheet_heading">
{{ section.settings.text_suche_bereich_bestseller }}
</div>
                                                  </div>
                                                  <ul class="predictive-search_product-list w-list-unstyled lh_search_sheet_product_grid" role="list">
                                                    {% for product in section.settings.collection_search_bestseller.products limit: section.settings.collection_search_bestseller_limit %}
<li class="predictive-search_produt-item">
    
                                                      
    <a class="predictive-search_line-item lh_search_sheet_product_card w-inline-block" li-object:href="product.url" href="{{ product.url }}">
                                                        <div class="predictive-search_image-wrapper lh_search_sheet_product_visual">
                                                          <img class="predictive-search_image" li-object:src="product.featured_image | img_url: 'master'" li-object:alt="product.featured_image.alt" alt="{{ product.featured_image.alt }}" src="{{ product.featured_image | img_url: 'master' }}" loading="lazy">
                                                        </div>
                                                        <div class="lh_search_sheet_rating" aria-hidden="true">
                                                          <span class="lh_search_sheet_rating_stars">★★★★★</span>
                                                           
                                                          <span class="lh_search_sheet_rating_val">4.9</span>
                                                        </div>
                                                        <div class="predictive-search_product-info lh_search_sheet_product_copy">
                                                          <div class="lh_search_sheet_product_titles">
                                                            <div class="text-size-regular text-weight-bold lh_search_sheet_product_title">
                                                              <span li-object="product.title">{{ product.title }}</span>
                                                            </div>
                                                            {% if product.type %}    <div class="lh_search_sheet_product_sub" li-if="product.type != blank" li-object="product.type">
    Typ    </div>
{% endif %}
                                                          </div>
                                                          <div class="text-size-small lh_search_sheet_product_price">
                                                            <span li-object="product.price | money">{{ product.price | money }}</span>
                                                          </div>
                                                        </div>
                                                      </a>
    
                                                    
</li>
{% endfor %}
                                                  </ul>
                                                </div>
                                              </div>
                                                </div>
{% endunless %} {% schema %} {
    "tag": "div",
    "name": "predictive_search",
    "class": "predictive-search_section",
    "blocks": [
        {
            "name": "Search - Suggestion",
            "type": "search-suggestion",
            "settings": [
                {
                    "id": "url_link",
                    "type": "url",
                    "label": "Link"
                },
                {
                    "id": "text_text",
                    "type": "text",
                    "label": "Text",
                    "default": "Tag"
                }
            ]
        }
    ],
    "settings": [
        {
            "id": "text_suche_treffer_vorschlage",
            "type": "text",
            "label": "Suche Treffer Vorschl\u00e4ge",
            "default": "Vorschl\u00e4ge"
        },
        {
            "id": "text_suche_treffer_produkte",
            "type": "text",
            "label": "Suche Treffer Produkte",
            "default": "Produkte"
        },
        {
            "id": "text_suche_treffer_seiten",
            "type": "text",
            "label": "Suche Treffer Seiten",
            "default": "Seiten"
        },
        {
            "id": "text_suche_bereich_vorschlage",
            "type": "text",
            "label": "Suche Bereich Vorschl\u00e4ge",
            "default": "Beliebte Suchanfragen"
        },
        {
            "id": "text_suche_bereich_bestseller",
            "type": "text",
            "label": "Suche Bereich Bestseller",
            "default": "K\u00fcrzlich angesehen"
        },
        {
            "id": "collection_search_bestseller",
            "type": "collection",
            "label": "Search - Bestseller"
        },
        {
            "type": "range",
            "id": "collection_search_bestseller_limit",
            "min": 1,
            "max": 99,
            "step": 1,
            "label": "Limit: Search - Bestseller",
            "default": 6
        }
    ],
    "presets": [
        {
            "name": "predictive_search",
            "category": "Liquify",
            "blocks": [
                {
                    "type": "search-suggestion"
                }
            ]
        }
    ]
} {% endschema %}