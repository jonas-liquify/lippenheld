<div class="padding-global lh_section_layout" style="{% if section.settings.bg_color != blank %}--lh-sec-bg: {{ section.settings.bg_color }};{% endif %}--lh-sec-pt: {{ section.settings.padding_top }}px;--lh-sec-pb: {{ section.settings.padding_bottom }}px;--lh-sec-px: {{ section.settings.padding_x }}px;"><div class="container-large"><div class="lh_founder_blocks" li-content-for-theme-blocks="">
{% content_for 'blocks' %}
</div></div></div> {% schema %} {
    "tag": "section",
    "name": "Founder Story",
    "class": "lh_founder",
    "blocks": [
        {
            "type": "_founder-bild"
        },
        {
            "type": "_founder-zitat"
        },
        {
            "type": "@app"
        }
    ],
    "settings": [
        {
            "type": "header",
            "content": "Layout"
        },
        {
            "type": "color",
            "id": "bg_color",
            "label": "Hintergrundfarbe (optional)",
            "default": "#ffffff"
        },
        {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 200,
            "step": 4,
            "unit": "px",
            "label": "Abstand oben",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "min": 0,
            "max": 200,
            "step": 4,
            "unit": "px",
            "label": "Abstand unten",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_x",
            "min": 0,
            "max": 120,
            "step": 4,
            "unit": "px",
            "label": "Abstand links\/rechts",
            "default": 0
        }
    ],
    "presets": [
        {
            "name": "Founder Story",
            "category": "Liquify",
            "blocks": [
                {
                    "type": "_founder-bild"
                },
                {
                    "type": "_founder-zitat"
                }
            ]
        }
    ]
} {% endschema %}