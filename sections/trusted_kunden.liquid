                        }
                    ]
                },
                {
                    "type": "_trusted-vorher-nachher",
                    "blocks": [
                        {
                            "type": "_ba-foto"
                        },
                        {
                            "type": "_ba-foto"
                        }
                    ]
                }
            ]
        }
    ]
} {% endschema %}