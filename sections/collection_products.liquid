        </div> {% schema %} {
    "tag": "section",
    "name": "Collection Products",
    "class": "section_filter",
    "settings": [
        {
            "id": "text_filter",
            "type": "text",
            "label": "Filter",
            "default": "Filters"
        },
        {
            "id": "text_clear_all",
            "type": "text",
            "label": "Clear all",
            "default": "Clear all"
        },
        {
            "id": "text_products_shown",
            "type": "text",
            "label": "Products shown",
            "default": "Products shown"
        }
    ],
    "presets": [
        {
            "name": "Collection Products",
            "category": "Liquify",
            "blocks": []
        }
    ],
    "enabled_on": {
        "templates": [
            "collection"
        ]
    }
} {% endschema %}