<div class="login_component">
            <div class="login_left" id="w-node-_175fd21a-17bf-bcb4-c19e-9a679b16ea24-9b16ea22">
              <div class="login_tabs w-tabs" data-duration-in="300" data-duration-out="100" id="w-node-_175fd21a-17bf-bcb4-c19e-9a679b16ea25-9b16ea22" data-current="Tab 1" data-easing="ease">
                <div class="login_tab-content w-tab-content">
                  <div class="login_tab-pane w-tab-pane w--tab-active" data-w-tab="Tab 1">
                    <div class="login_form w-form">
                      <h1 class="heading-style-h2 text-align-center">
{{ section.settings.text_login }}
</h1>
                      {% form 'customer_login', return_to: '/account', class: 'form_form' %}
{% if form.errors %}    <div class="form_error-message" li-if="form.errors">
    
                          <div class="text-size-regular text-color-red text-align-center" li-object="form.errors | default_errors">{{ form.errors | default_errors }}</div>
                            </div>
{% endif %}
                        <div class="form_field-wrapper">
                          <label class="form_hidden-label" for="field-4">Email Address</label>
                          <input class="form_input w-input" maxlength="256" name="customer[email]" data-name="Field 4" type="email" id="field-4" placeholder="Email Address">
                        </div>
                        <div class="form_field-wrapper">
                          <label class="form_hidden-label" for="field-4">Password</label>
                          <input class="form_input w-input" maxlength="256" name="customer[password]" data-name="Field 4" type="password" id="field-4" required="" placeholder="Password">
                        </div>
                        <input class="button max-width-full w-button" type="submit" data-wait="Please Wait" id="w-node-_175fd21a-17bf-bcb4-c19e-9a679b16ea37-9b16ea22" value="Login">
                      {% endform %}
                      <div class="text-size-regular text-align-center">
                        <span>
{{ section.settings.text_no_account_yet }}
</span>
                         
                        <a class="text-style-link text-weight-bold" href="{{ routes.account_register_url }}" li-object:href="routes.account_register_url">Register now</a>
                      </div>
                      <div class="w-form-done">
                        <div>Thank you! Your submission has been received!</div>
                      </div>
                      <div class="login_hinweis-kachel w-form-fail">
                        <div>Oops! Something went wrong while submitting the form.</div>
                      </div>
                    </div>
                  </div>
                  <div class="login_tab-pane w-tab-pane" data-w-tab="Tab 2">
                    <div class="login_form w-form">
                      <h2 class="heading-style-h2 text-align-center">
{{ section.settings.text_reset_password }}
</h2>
                      <p class="text-size-regular text-align-center">
{{ section.settings.text_password_text }}
</p>
                      {% form 'recover_customer_password', class: 'form_form' %}
<div class="form_field-wrapper">
                          <label class="form_hidden-label" for="field-4">Email Address</label>
                          <input class="form_input w-input" maxlength="256" name="email" data-name="Field 4" type="email" id="field-4" placeholder="Email Address">
                        </div>
                        <input class="button max-width-full w-button" type="submit" data-wait="Please wait..." value="Reset">
                      {% endform %}
                      <div class="w-form-done">
                        <div>Thank you! Your submission has been received!</div>
                      </div>
                      <div class="w-form-fail">
                        <div>Oops! Something went wrong while submitting the form.</div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="login_tab-menu w-tab-menu">
                  <a class="login_tab-link w-inline-block w-tab-link w--current" data-w-tab="Tab 1">
                    <div class="text-style-link text-weight-bold">Login</div>
                  </a>
                   
                  <a class="login_tab-link w-inline-block w-tab-link" data-w-tab="Tab 2">
                    <div>
                      <span>
{{ section.settings.text_forgot_password }}
</span>
                       
                      <span class="text-style-link text-weight-bold">Rest now!</span>
                    </div>
                  </a>
                </div>
              </div>
            </div>
            <div class="login_image-wrapper" id="w-node-_175fd21a-17bf-bcb4-c19e-9a679b16ea5d-9b16ea22">
              {% if section.settings.image_bild %}
{{ section.settings.image_bild | image_url: width: 800 | image_tag: class: 'login_image', loading: 'lazy', id: 'w-node-_175fd21a-17bf-bcb4-c19e-9a679b16ea5e-9b16ea22' }}
{% else %}
<img class="login_image" src="{{ 'hero-apparel-1.svg' | asset_url }}" loading="lazy" id="w-node-_175fd21a-17bf-bcb4-c19e-9a679b16ea5e-9b16ea22" alt="">
{% endif %}
            </div>
          </div> {% schema %} {
    "tag": "section",
    "name": "Login",
    "class": "section_login",
    "settings": [
        {
            "id": "text_login",
            "type": "text",
            "label": "Login",
            "default": "Login"
        },
        {
            "id": "text_no_account_yet",
            "type": "text",
            "label": "No Account yet",
            "default": "No Account yet?"
        },
        {
            "id": "text_reset_password",
            "type": "text",
            "label": "Reset Password",
            "default": "Reset Password"
        },
        {
            "id": "text_password_text",
            "type": "text",
            "label": "Password Text",
            "default": "In order to receive a new password, you need to enter your email address below, and we will send you an email with further instructions immediately."
        },
        {
            "id": "text_forgot_password",
            "type": "text",
            "label": "Forgot password",
            "default": "Forgot password?"
        },
        {
            "id": "image_bild",
            "type": "image_picker",
            "label": "Bild"
        }
    ],
    "presets": [
        {
            "name": "Login",
            "category": "Liquify",
            "blocks": []
        }
    ],
    "enabled_on": {
        "templates": [
            "customers\/login"
        ]
    }
} {% endschema %}