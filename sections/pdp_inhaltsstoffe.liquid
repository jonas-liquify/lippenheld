<div class="lh_pdp_ingredients_grid"><div class="lh_pdp_ingredients_col lh_pdp_ingredients_col_list"><p class="lh_pdp_ingredients_label">
{{ section.settings.text_spalte_1_label }}
</p><ol class="lh_pdp_ingredients_ol" li-content-for-theme-blocks="">
{% content_for 'blocks' %}
</ol><div class="lh_pdp_ingredients_inci lh_text_playfair"> {{ section.settings.richtext_inci_langtext }} </div></div><div class="lh_pdp_ingredients_col lh_pdp_ingredients_col_visual">{% if section.settings.image_mittleres_bild %}
{{ section.settings.image_mittleres_bild | image_url: width: 1000 | image_tag: class: 'lh_pdp_ingredients_hero', loading: 'lazy' }}
{% else %}
<img class="lh_pdp_ingredients_hero" src="{{ 'platzhalter.svg' | asset_url }}" alt="" loading="lazy">
{% endif %}</div><div class="lh_pdp_ingredients_col lh_pdp_ingredients_col_story"><p class="lh_pdp_ingredients_kicker">
{{ section.settings.text_spalte_3_kicker }}
</p><h2 class="lh_pdp_ingredients_headline">
{{ section.settings.text_headline }}
</h2><div class="lh_pdp_ingredients_copy lh_text_playfair"> {{ section.settings.richtext_fliesstext_1 }} </div><div class="lh_pdp_ingredients_copy lh_text_playfair"> {{ section.settings.richtext_fliesstext_2 }} </div><a class="lh_btn lh_btn--black lh_pdp_ingredients_btn" href="{{ section.settings.url_button_link }}"> {{ section.settings.text_button }} </a></div></div> {% schema %} {
    "tag": "section",
    "name": "PDP Inhaltsstoffe",
    "class": "lh_pdp_section lh_pdp_ingredients",
    "blocks": [
        {
            "type": "_inhaltszeile"
        },
        {
            "type": "@app"
        }
    ],
    "settings": [
        {
            "id": "text_spalte_1_label",
            "type": "text",
            "label": "Spalte 1 Label",
            "default": "ingredients"
        },
        {
            "id": "richtext_inci_langtext",
            "type": "richtext",
            "label": "INCI Langtext",
            "default": "<p>FULL INGREDIENTS \u2014 Cera Alba, \u2026<\/p>"
        },
        {
            "id": "image_mittleres_bild",
            "type": "image_picker",
            "label": "Mittleres Bild"
        },
        {
            "id": "text_spalte_3_kicker",
            "type": "text",
            "label": "Spalte 3 Kicker",
            "default": "ingredients"
        },
        {
            "id": "text_headline",
            "type": "text",
            "label": "Headline",
            "default": "HYDROXYTYROSOL"
        },
        {
            "id": "richtext_fliesstext_1",
            "type": "richtext",
            "label": "Fliesstext 1",
            "default": "<p>Hydroxytyrosol ist ein wahrer Power-Inhaltsstoff. Das nat\u00fcrliche Antioxidans hat eine Menge Vorteile f\u00fcr unsere Haut.<\/p>"
        },
        {
            "id": "richtext_fliesstext_2",
            "type": "richtext",
            "label": "Fliesstext 2",
            "default": "<p>Hydroxytyrosol sch\u00fctzt die Haut vor oxidativem Stress und wirkt entz\u00fcndungshemmend.<\/p>"
        },
        {
            "id": "url_button_link",
            "type": "url",
            "label": "Button Link"
        },
        {
            "id": "text_button",
            "type": "text",
            "label": "Button",
            "default": "Mehr erfahren"
        }
    ],
    "presets": [
        {
            "name": "PDP Inhaltsstoffe",
            "category": "Produktseite",
            "blocks": [
                {
                    "type": "_inhaltszeile"
                },
                {
                    "type": "_inhaltszeile"
                },
                {
                    "type": "_inhaltszeile"
                },
                {
                    "type": "_inhaltszeile"
                },
                {
                    "type": "_inhaltszeile"
                }
            ]
        }
    ]
} {% endschema %}