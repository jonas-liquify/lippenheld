<div class="login_component">
            <div class="login_left" id="w-node-_020413c5-8dec-2c46-93a1-274ba44a608a-a44a6088">
              <div class="login_tabs" id="w-node-_020413c5-8dec-2c46-93a1-274ba44a608b-a44a6088">
                <div class="login_form w-form">
                  <h1 class="heading-style-h2 text-align-center">
{{ section.settings.text_create_account }}
</h1>
                  {% form 'create_customer', return_to: '/', class: 'form_form' %}
{% if form.errors %}    <div class="form_error-message" li-if="form.errors">
    
                      <div class="text-size-regular text-color-red text-align-center" li-object="form.errors | default_errors">{{ form.errors | default_errors }}</div>
                        </div>
{% endif %}
                    <div class="form_field-wrapper">
                      <label class="form_hidden-label" for="field-5">First Name</label>
                      <input class="form_input w-input" maxlength="256" name="customer[first_name]" data-name="Field 5" type="text" id="field-5" required="" placeholder="First Name">
                    </div>
                    <div class="form_field-wrapper">
                      <label class="form_hidden-label" for="field-5">Last Name</label>
                      <input class="form_input w-input" maxlength="256" name="customer[last_name]" data-name="Field 5" type="text" id="field-5" required="" placeholder="Last Name">
                    </div>
                    <div class="form_field-wrapper">
                      <label class="form_hidden-label" for="field-5">Email Address</label>
                      <input class="form_input w-input" maxlength="256" name="customer[email]" data-name="Field 5" type="email" id="field-5" required="" placeholder="Email Address">
                    </div>
                    <div class="form_field-wrapper">
                      <label class="form_hidden-label" for="field-5">Password</label>
                      <input class="form_input w-input" maxlength="256" name="customer[password]" data-name="Field 5" type="password" id="field-5" required="" placeholder="Password">
                    </div>
                    <label class="w-checkbox form_checkbox">
                      <input class="w-checkbox-input form_checkbox-icon" type="checkbox" name="" data-name="" required="">
                      <span class="form_checkbox-label w-form-label">
{{ section.settings.text_checkbox_legal }}
</span>
                       
                    </label>
                     
                    <label class="w-checkbox form_checkbox">
                      <input class="w-checkbox-input form_checkbox-icon" type="checkbox" name="customer[accepts_marketing]" data-name="">
                      <span class="form_checkbox-label w-form-label">
{{ section.settings.text_checkbox_marketing }}
</span>
                    </label>
                    <input class="button max-width-full w-button" type="submit" data-wait="Please wait" id="w-node-_020413c5-8dec-2c46-93a1-274ba44a60ab-a44a6088" value="Register now">
                  {% endform %}
                  <div class="text-size-regular text-align-center">
                    <span>
{{ section.settings.text_already_have_an_account }}
</span>
                     
                    <a class="text-style-link text-weight-bold" href="{{ routes.account_login_url }}" li-object:href="routes.account_login_url">Login now</a>
                  </div>
                  <div class="hide w-form-done">
                    <div>Thank you! Your submission has been received!</div>
                  </div>
                  <div class="hide w-form-fail">
                    <div>Oops! Something went wrong while submitting the form.</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="login_image-wrapper" id="w-node-_020413c5-8dec-2c46-93a1-274ba44a60b6-a44a6088">
              {% if section.settings.image_bild %}
{{ section.settings.image_bild | image_url: width: 800 | image_tag: class: 'login_image', loading: 'lazy', id: 'w-node-_020413c5-8dec-2c46-93a1-274ba44a60b7-a44a6088' }}
{% else %}
<img class="login_image" src="{{ 'hero-apparel-1.svg' | asset_url }}" loading="lazy" id="w-node-_020413c5-8dec-2c46-93a1-274ba44a60b7-a44a6088" alt="">
{% endif %}
            </div>
          </div> {% schema %} {
    "tag": "section",
    "name": "Register",
    "class": "section_login",
    "settings": [
        {
            "id": "text_create_account",
            "type": "text",
            "label": "Create Account",
            "default": "Create Account"
        },
        {
            "id": "text_checkbox_legal",
            "type": "text",
            "label": "Checkbox Legal",
            "default": "Checkbox Legal"
        },
        {
            "id": "text_checkbox_marketing",
            "type": "text",
            "label": "Checkbox Marketing",
            "default": "Checkbox Marketing"
        },
        {
            "id": "text_already_have_an_account",
            "type": "text",
            "label": "Already have an Account",
            "default": "Already have an Account?"
        },
        {
            "id": "image_bild",
            "type": "image_picker",
            "label": "Bild"
        }
    ],
    "presets": [
        {
            "name": "Register",
            "category": "Liquify",
            "blocks": []
        }
    ],
    "enabled_on": {
        "templates": [
            "customers\/register"
        ]
    }
} {% endschema %}