<div class="padding-global padding-section-large">
            <div class="container-large">
              <div class="login_tabs">
                <div class="login_form w-form">
                  <h1 class="heading-style-h2 text-align-center">
{{ section.settings.text_activate_account }}
</h1>
                  {% form 'activate_customer_password', class: 'form_form' %}
{% if form.errors %}    <div class="form_error-message" li-if="form.errors">
    
                      <div class="text-size-regular text-color-red text-align-center" li-object="form.errors | default_errors">{{ form.errors | default_errors }}</div>
                        </div>
{% endif %}
                    <div class="form_field-wrapper">
                      <label class="form_hidden-label" for="field-3">Password</label>
                      <input class="form_input w-input" maxlength="256" name="customer[password]" data-name="Field 3" type="password" id="field-3" required="" placeholder="Password">
                    </div>
                    <div class="form_field-wrapper">
                      <label class="form_hidden-label" for="field-3">Repeat Password</label>
                      <input class="form_input w-input" maxlength="256" name="customer[password_confirmation]" data-name="Field 3" type="password" id="field-3" required="" placeholder="Repeat Password">
                    </div>
                    <div class="button-group">
                      <input class="button max-width-full w-button" type="submit" data-wait="" value="Activate">
                      <input class="button is-outline max-width-full w-button" type="submit" data-wait="" value="Refuse" name="decline">
                    </div>
                  {% endform %}
                  <div class="w-form-done">
                    <div>Thank you! Your submission has been received!</div>
                  </div>
                  <div class="w-form-fail">
                    <div>Oops! Something went wrong while submitting the form.</div>
                  </div>
                </div>
              </div>
            </div>
          </div> {% schema %} {
    "tag": "section",
    "name": "Activate-Account",
    "class": "section_newsletter",
    "settings": [
        {
            "id": "text_activate_account",
            "type": "text",
            "label": "Activate Account",
            "default": "Activate Account"
        }
    ],
    "presets": [
        {
            "name": "Activate-Account",
            "category": "Liquify",
            "blocks": []
        }
    ],
    "enabled_on": {
        "templates": [
            "customers\/activate_account"
        ]
    }
} {% endschema %}