<div class="padding-global lh_section_layout" style="{% if section.settings.bg_color != blank %}--lh-sec-bg: {{ section.settings.bg_color }};{% endif %}--lh-sec-pt: {{ section.settings.padding_top }}px;--lh-sec-pb: {{ section.settings.padding_bottom }}px;--lh-sec-px: {{ section.settings.padding_x }}px;"><div class="container-large"><div class="lh_reviews_inner"><div class="lh_section_head"><p class="lh_kicker">
{{ section.settings.text_lip_uberschrift }}
</p><div class="lh_text_playfair"> {{ section.settings.richtext_lip_text }} </div></div><div class="lh_lip_swiper swiper lh_swiper lh_swiper_lip"><div class="swiper-wrapper" li-content-for-theme-blocks="">
{% content_for 'blocks' %}
</div><div class="swiper-scrollbar lh_lip_scrollbar" aria-hidden="true"></div></div></div></div></div> {% schema %} {
    "tag": "section",
    "name": "Lippen Problem",
    "class": "lh_lip_problem",
    "blocks": [
        {
            "type": "_lip-kachel"
        },
        {
            "type": "@app"
        }
    ],
    "settings": [
        {
            "type": "header",
            "content": "Layout"
        },
        {
            "type": "color",
            "id": "bg_color",
            "label": "Hintergrundfarbe",
            "default": "#afbaab"
        },
        {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 200,
            "step": 4,
            "unit": "px",
            "label": "Abstand oben",
            "default": 80
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "min": 0,
            "max": 200,
            "step": 4,
            "unit": "px",
            "label": "Abstand unten",
            "default": 80
        },
        {
            "type": "range",
            "id": "padding_x",
            "min": 0,
            "max": 120,
            "step": 4,
            "unit": "px",
            "label": "Abstand links\/rechts",
            "default": 60
        },
        {
            "id": "text_lip_uberschrift",
            "type": "text",
            "label": "Lip \u00dcberschrift",
            "default": "Was ist dein Lippenproblem?"
        },
        {
            "id": "richtext_lip_text",
            "type": "richtext",
            "label": "Lip Text",
            "default": "<p>Nicht sicher, welcher Lippenheld f\u00fcr dich passt? W\u00e4hle einfach den Zustand deiner Lippen aus.<\/p>"
        }
    ],
    "presets": [
        {
            "name": "Lippen Problem",
            "category": "Liquify",
            "blocks": [
                {
                    "type": "_lip-kachel"
                },
                {
                    "type": "_lip-kachel"
                },
                {
                    "type": "_lip-kachel"
                },
                {
                    "type": "_lip-kachel"
                }
            ]
        }
    ]
} {% endschema %}