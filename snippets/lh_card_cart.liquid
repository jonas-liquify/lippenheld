<div class="lh_product_card_stack"><div class="lh_product_visual"><img src="{{ block.settings.card_product.featured_image | image_url: width: 900 }}" alt="{{ block.settings.card_product.featured_image.alt }}" loading="lazy" li-object:src="block.settings.card_product.featured_image | image_url: width: 900" li-object:alt="block.settings.card_product.featured_image.alt"><a class="lh_btn lh_btn--white lh_product_card_atc" href="{% if block.settings.card_product != blank %}{{ block.settings.card_product.url }}{% else %}#{% endif %}">In den Warenkorb</a></div><div class="lh_stars_row" aria-hidden="true"><span class="lh_star">★</span> <span class="lh_star">★</span> <span class="lh_star">★</span> <span class="lh_star">★</span> <span class="lh_star">★</span> <span class="lh_rating_num">4.9</span></div><p class="lh_product_title" li-object="block.settings.card_product.title">{{ block.settings.card_product.title }}</p><p class="lh_product_sub" li-object="block.settings.card_product.type">{{ block.settings.card_product.type }}</p><p class="lh_price" li-object="block.settings.card_product.price | money">{{ block.settings.card_product.price | money }}</p></div>
