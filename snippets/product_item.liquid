<script src="{{ 'li_custom.js' | asset_url }}" type="text/javascript"></script>
<div class="product-item_component" li-element="product-variant-container" x-data="handleVariant({{ product | json | escape }}, {{ product.options_by_name | json | escape }}, {{ product.selected_or_first_available_variant | json | escape }})" x-init="$nextTick(() => { activateVariants() })" @setbundleitem.window="updateBundleItem($event.detail.product, $event.detail.quantity)"><div class="product-item_image-link"><a class="product-item_image-wrapper w-inline-block" li-object:href="product.url" href="{{ product.url }}"><img class="product-item_image" li-object:alt="product.featured_image.alt" loading="lazy" li-object:src="product.featured_image | image_url: width: 450" src="{{ product.featured_image | image_url: width: 450 }}" alt="{{ product.featured_image.alt }}"></a><div class="product-item_tag_list">{% if product.selected_or_first_available_variant.available != true %}    <div class="product-item_tag" li-if="product.selected_or_first_available_variant.available != true">
    Not in Stock    </div>
{% endif %}{% if product.compare_at_price_max > product.price %}    <div class="product-item_tag is-red" li-if="product.compare_at_price_max > product.price">
    Sale    </div>
{% endif %}</div></div><div class="spacer-xxsmall"></div><a class="product-item_text-link w-inline-block" li-object:href="product.url" href="{{ product.url }}"><div class="product-item_left"><div class="text-size-small" li-object="product.vendor">{{ product.vendor }}</div><div class="heading-style-h4 text-weight-normal" li-object="product.title">{{ product.title }}</div></div><div class="product-item_price">{% if product.compare_at_price_max > product.price %}    <div li-if="product.compare_at_price_max > product.price">
    <div class="text-size-regular text-style-strikethrough text-style-muted" li-object="product.compare_at_price | money">{{ product.compare_at_price | money }}</div>    </div>
{% endif %}<div class="text-size-regular" li-object="product.price | money">{{ product.price | money }}</div></div></a><div class="spacer-small"></div><div class="margin-top-auto"><div class="product-item_form-wrapper">{% if product.available == true %}    <div li-if="product.available == true">
    <a class="button max-width-full w-button" li-element="add-to-cart" href="#" @click="addToCart($event, true)" :disabled="!addToCartButton">Add to Cart</a>    </div>
{% endif %}{% if product.available != true %}    <div li-if="product.available != true">
    <a class="button is-secondary pointer-events-off max-width-full w-button" href="#">Not in Stock</a>    </div>
{% endif %}</div></div></div>
